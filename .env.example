NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Option A: direct Postgres connection string for psql-based smoke tests and SQL apply scripts.
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres
# Option B: keep NEXT_PUBLIC_SUPABASE_URL and provide only the database password; the SQL tooling derives the direct Postgres URL automatically.
# SUPABASE_DB_PASSWORD=your-db-password
# Optional override when psql is not available in PATH or in a standard Windows PostgreSQL install, for example:
# PSQL_PATH=C:\Program Files\PostgreSQL\17\bin\psql.exe
